# Application
APP_NAME=NEF IA API
APP_ENV=local
APP_DEBUG=true
API_PREFIX=/api/v1
APP_PORT=8000

# Security
SECRET_KEY=change-me-in-production
ADMIN_JWT_ALGORITHM=HS256
ADMIN_JWT_EXPIRE_MINUTES=60
API_TOKEN_PREFIX=ia_live
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIALS_ENCRYPTION_KEY=replace-with-fernet-key

# Logging
LOG_LEVEL=INFO

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database (operational)
# Preferred configuration: use DB_* and let the app build DATABASE_URL internally.
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=nef_ia
# Optional legacy override (takes precedence over DB_* when set):
# DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/nef_ia

# Shared database (optional)
# Priority:
# 1) SHARED_DATABASE_URL
# 2) SHARED_DB_* (all fields below)
# 3) fallback to operational resolved database URL
# SHARED_DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/nef_ia
# SHARED_DB_HOST=postgres
# SHARED_DB_PORT=5432
# SHARED_DB_USER=postgres
# SHARED_DB_PASSWORD=postgres
# SHARED_DB_NAME=nef_ia
SQLALCHEMY_ECHO=false

# Redis
REDIS_URL=redis://redis:6379/0

# Queue
QUEUE_BACKEND=dramatiq
QUEUE_NAME=nef_ia.executions
WORKER_PREFETCH_MULTIPLIER=1
WORKER_CONCURRENCY=2

# Provider execution controls
MAX_TOKENS=1500
MAX_TOKENS_PER_EXECUTION=10000
TEMPERATURE=0.2
PROVIDER_TIMEOUT=120
PROVIDER_TIMEOUT_SECONDS=120
ANTHROPIC_API_VERSION=2023-06-01
MAX_RETRIES=3
RETRY_BACKOFF=2
RETRY_BACKOFF_SECONDS=2
MAX_COST_PER_EXECUTION=10
MAX_CONCURRENT_EXECUTIONS=4
CHUNK_SIZE_CHARACTERS=8000
MAX_INPUT_CHARACTERS=20000
ALERT_FAILURE_STREAK_THRESHOLD=5
ALERT_COST_THRESHOLD=100
ALERT_QUEUE_STUCK_MINUTES=15

# Storage
STORAGE_PATH=/app/storage
MAX_UPLOAD_SIZE_MB=1024
UPLOAD_CHUNK_SIZE_BYTES=1048576
ALLOWED_FILE_EXTENSIONS=.xlsx,.xls,.csv,.pdf
ALLOWED_FILE_MIME_TYPES=application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-excel,text/csv,application/csv,text/plain,application/pdf,application/octet-stream
