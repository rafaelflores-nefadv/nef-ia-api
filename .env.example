# Application
APP_NAME=NEF IA API
APP_ENV=local
APP_DEBUG=true
API_PREFIX=/api/v1
APP_PORT=8000

# Security
SECRET_KEY=change-me-in-production
ADMIN_JWT_ALGORITHM=HS256
ADMIN_JWT_EXPIRE_MINUTES=60
API_TOKEN_PREFIX=ia_live
# Must be a valid Fernet key before creating/updating provider credentials.
# The placeholder below is intentionally invalid and is safe only until those flows are used.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIALS_ENCRYPTION_KEY=replace-with-fernet-key
TEST_PROMPTS_AUTOMATION_SLUG=system-test-automation
TEST_PROMPTS_AUTOMATION_NAME=Automacao Tecnica de Teste
# Optional fixed UUID for the official shared technical automation used internally by prompt tests:
# TEST_PROMPTS_AUTOMATION_ID=

# Logging
LOG_LEVEL=INFO

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database (operational)
# Preferred configuration: use DB_* and let the app build DATABASE_URL internally.
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=nef_ia
# Optional legacy override (takes precedence over DB_* when set):
# DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/nef_ia

# Shared database (optional)
# Priority:
# 1) SHARED_DATABASE_URL
# 2) SHARED_DB_* (all fields below)
# 3) fallback to operational resolved database URL
# SHARED_DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/nef_ia
# SHARED_DB_HOST=postgres
# SHARED_DB_PORT=5432
# SHARED_DB_USER=postgres
# SHARED_DB_PASSWORD=postgres
# SHARED_DB_NAME=nef_ia
SQLALCHEMY_ECHO=false

# Redis
REDIS_URL=redis://redis:6379/0

# Django admin (local)
DJANGO_SECRET_KEY=django-insecure-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_DB_ENGINE=django.db.backends.postgresql
DJANGO_DB_HOST=127.0.0.1
DJANGO_DB_PORT=5432
DJANGO_DB_NAME=nef_ia_django
DJANGO_DB_USER=postgres
DJANGO_DB_PASSWORD=postgres
# Optional compatibility for non-local environments:
# DJANGO_DB_SSLMODE=require
# DJANGO_DB_CHARSET=utf8mb4
FASTAPI_BASE_URL=http://127.0.0.1:8000
FASTAPI_TIMEOUT_SECONDS=2.5
# Prompt-test execution can be long (tabular row-by-row). Keep read timeout high.
FASTAPI_PROMPT_TEST_CONNECT_TIMEOUT_SECONDS=2.5
FASTAPI_PROMPT_TEST_READ_TIMEOUT_SECONDS=240
FASTAPI_PROMPT_TEST_WRITE_TIMEOUT_SECONDS=60
FASTAPI_PROMPT_TEST_POOL_TIMEOUT_SECONDS=30
# FASTAPI_ADMIN_TOKEN=

# Queue
QUEUE_BACKEND=dramatiq
QUEUE_NAME=nef_ia.executions
WORKER_PREFETCH_MULTIPLIER=1
WORKER_CONCURRENCY=2

# Provider execution controls
MAX_TOKENS=1500
MAX_TOKENS_PER_EXECUTION=10000
TEMPERATURE=0.2
PROVIDER_TIMEOUT=120
PROVIDER_TIMEOUT_SECONDS=120
ANTHROPIC_API_VERSION=2023-06-01
MAX_RETRIES=3
MAX_JOB_RETRIES_HARD_LIMIT=20
RETRY_BACKOFF=2
RETRY_BACKOFF_SECONDS=2
MAX_COST_PER_EXECUTION=10
MAX_CONCURRENT_EXECUTIONS=4
MAX_EXECUTION_SECONDS_HARD_LIMIT=7200
MAX_EXECUTION_ROWS_HARD_LIMIT=100000
MAX_PROVIDER_CALLS_HARD_LIMIT=10000
MAX_TEXT_CHUNKS_HARD_LIMIT=5000
MAX_TABULAR_ROW_CHARACTERS_HARD_LIMIT=50000
EXECUTION_PROFILE_DEFAULT=standard
# JSON (recommended) or csv format: "automation_uuid=heavy,other_uuid=extended"
EXECUTION_PROFILE_AUTOMATION_OVERRIDES=
EXECUTION_PROFILE_STANDARD_MAX_EXECUTION_ROWS=25000
EXECUTION_PROFILE_STANDARD_MAX_PROVIDER_CALLS=2500
EXECUTION_PROFILE_STANDARD_MAX_TEXT_CHUNKS=1200
EXECUTION_PROFILE_STANDARD_MAX_TABULAR_ROW_CHARACTERS=12000
EXECUTION_PROFILE_STANDARD_MAX_EXECUTION_SECONDS=1800
EXECUTION_PROFILE_STANDARD_MAX_CONTEXT_CHARACTERS=8000
EXECUTION_PROFILE_STANDARD_MAX_CONTEXT_FILE_CHARACTERS=2500
EXECUTION_PROFILE_STANDARD_MAX_PROMPT_CHARACTERS=12000
EXECUTION_PROFILE_HEAVY_MAX_EXECUTION_ROWS=60000
EXECUTION_PROFILE_HEAVY_MAX_PROVIDER_CALLS=6000
EXECUTION_PROFILE_HEAVY_MAX_TEXT_CHUNKS=3000
EXECUTION_PROFILE_HEAVY_MAX_TABULAR_ROW_CHARACTERS=30000
EXECUTION_PROFILE_HEAVY_MAX_EXECUTION_SECONDS=5400
EXECUTION_PROFILE_HEAVY_MAX_CONTEXT_CHARACTERS=11000
EXECUTION_PROFILE_HEAVY_MAX_CONTEXT_FILE_CHARACTERS=3200
EXECUTION_PROFILE_HEAVY_MAX_PROMPT_CHARACTERS=18000
EXECUTION_PROFILE_EXTENDED_MAX_EXECUTION_ROWS=90000
EXECUTION_PROFILE_EXTENDED_MAX_PROVIDER_CALLS=9000
EXECUTION_PROFILE_EXTENDED_MAX_TEXT_CHUNKS=4500
EXECUTION_PROFILE_EXTENDED_MAX_TABULAR_ROW_CHARACTERS=45000
EXECUTION_PROFILE_EXTENDED_MAX_EXECUTION_SECONDS=6600
EXECUTION_PROFILE_EXTENDED_MAX_CONTEXT_CHARACTERS=12000
EXECUTION_PROFILE_EXTENDED_MAX_CONTEXT_FILE_CHARACTERS=3500
EXECUTION_PROFILE_EXTENDED_MAX_PROMPT_CHARACTERS=20000
CHUNK_SIZE_CHARACTERS=8000
MAX_INPUT_CHARACTERS=20000
MAX_CONTEXT_CHARACTERS=12000
MAX_CONTEXT_FILE_CHARACTERS=3500
MAX_PROMPT_CHARACTERS=20000
ALERT_FAILURE_STREAK_THRESHOLD=5
ALERT_COST_THRESHOLD=100
ALERT_QUEUE_STUCK_MINUTES=15

# Storage
STORAGE_PATH=/app/storage
MAX_UPLOAD_SIZE_MB=1024
UPLOAD_CHUNK_SIZE_BYTES=1048576
ALLOWED_FILE_EXTENSIONS=.xlsx,.csv,.pdf
ALLOWED_FILE_MIME_TYPES=application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-excel,text/csv,application/csv,text/plain,application/pdf,application/octet-stream
